# Server
NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/mern_prototype

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1h

# CORS (comma-separated origins, * allowed for dev only)
CORS_ORIGIN=http://localhost:3000

# External API used by the real-time stream service
EXTERNAL_API_URL=https://api.coindesk.com/v1/bpi/currentprice.json
EXTERNAL_API_POLL_MS=10000

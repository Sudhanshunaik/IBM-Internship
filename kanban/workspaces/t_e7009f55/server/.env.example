# Server environment variables
# Copy to `.env` and fill in values for local dev. NEVER commit `.env`.

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173

# Mongo
MONGO_URI=mongodb://localhost:27017/mern_3dviz

# Auth
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_at_least_32_chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Cookie
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# Real-time
SOCKET_PATH=/socket.io
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_PING_INTERVAL_MS=25000